      </p>
      <p xml:space="preserve">
        <docTitle refersTo="#adoption">Adopted by the Security Council at its <inline name="adoptionMeeting" title="10119th">10119th meeting</inline>, on<docDate date="2026-03-11" refersTo="#adoptionDate">11 March 2026</docDate></docTitle>
