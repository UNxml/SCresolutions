      <p xml:space="preserve">
        <docTitle refersTo="#resolutionNumber">Resolution 2825 (2026)</docTitle>
      </p>
      <p xml:space="preserve">
        <docTitle refersTo="#adoption">Adopted by the Security Council at its <inline name="adoptionMeeting" title="10188th">10188th meeting</inline>, on<docDate date="2026-06-29" refersTo="#adoptionDate">29 June 2026</docDate></docTitle>
