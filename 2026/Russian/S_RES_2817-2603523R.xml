      <p xml:space="preserve">
        <docTitle refersTo="#adoption">принятая Советом Безопасности на его <inline name="adoptionMeeting" title="10119-м">10119-м заседании </inline><docDate date="2026-03-11" refersTo="#adoptionDate">11 марта 2026 года</docDate></docTitle>
      </p>
