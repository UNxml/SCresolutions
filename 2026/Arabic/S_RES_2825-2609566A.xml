    <preamble>
      <formula name="enactingFormula" eId="formula_1">
        <p xml:space="preserve">
          <span class="bold italic">إن مجلس الأمن،</span>
        </p>
      </formula>
      <container name="إذ يشير" eId="container_2">
        <p xml:space="preserve">	<span class="bold italic">إذ يشير </span>إلى قراراته السابقة المتعلقة بجمهورية الكونغو الديمقراطية،</p>
      </container>
      <container name="وإذ يؤكد من جديد" eId="container_3">
        <p xml:space="preserve">	<span class="bold italic">وإذ يؤكد من جديد </span>التزامه القوي بسيادة جمهورية الكونغو الديمقراطية وجميع دول المنطقة وباستقلالها ووحدتها وسلامتها الإقليمية، وإذ يشدد على ضرورة الاحترام الكامل لمبادئ عدم التدخل وحسن الجوار والتعاون الإقليمي،</p>
      </container>
      <container name="وإذ يكرر تأكيد" eId="container_4">
        <p xml:space="preserve">	<span class="bold italic">وإذ يكرر تأكيد </span>ضرورة التنفيذ الكامل للقرارين <a href="https://docs.un.org/ar/S/RES/2773(2025)">2773 (2025)</a> و <a href="https://docs.un.org/ar/S/RES/2808(2025)">2808 (2025)</a>، بما في ذلك الوقف الفوري للأعمال العدائية، والانسحاب غير المشروط لقوات الدفاع الرواندية من أراضي جمهورية الكونغو الديمقراطية، فضلاً عن وقف ما تقدمه حركة 23 مارس والقوات العسكرية لجمهورية الكونغو الديمقراطية من دعم لجماعات مسلحة محددة، ولا سيما القوات الديمقراطية لتحرير رواندا،</p>
      </container>
      <container name="وإذ يعرب عن القلق" eId="container_5">
        <p xml:space="preserve">
          <span class="bold italic">	وإذ يعرب عن القلق </span>إزاء انتهاكات حظر توريد الأسلحة التي تم توثيقها في تقارير فريق الخبراء المعني بجمهورية الكونغو الديمقراطية (”فريق الخبراء“) الذي أنشئ عملاً بالقرار <a href="https://docs.un.org/ar/S/RES/1533(2004)">1533 (2004)</a> وتم تمديد ولايته عملاً بقرارات لاحقة،</p>
      </container>
      <container name="وإذ يعرب عن القلق" eId="container_6">
        <p xml:space="preserve">
          <span class="bold italic">	وإذ يعرب عن القلق </span>بشأن وجود صلات، على النحو الذي وثّقه فريق الخبراء، بين القوات الديمقراطية المتحالفة والجماعات الإرهابية الدولية، وهو ما يزيد من تفاقم النزاعات ويسهم في تقويض سلطة الدولة، ويشكل خطرا جسيما يهدد المدنيين والاستقرار الإقليمي،</p>
      </container>
      <container name="وإذ يدين" eId="container_7">
        <p xml:space="preserve">	<span class="bold italic">وإذ يدين </span>جميع التهديدات الموجهة ضد سلامة وأمن حفظة السلام وموظفي الأمم المتحدة، وكذلك الأعمال التي تعرقل تنفيذ ولاية بعثة منظمة الأمم المتحدة لتحقيق الاستقرار في جمهورية الكونغو الديمقراطية،</p>
      </container>
      <container name="وإذ يعيد تأكيد قلقه" eId="container_8">
        <p xml:space="preserve">	<span class="bold italic">وإذ يعيد تأكيد قلقه </span>إزاء معاناة السكان المدنيين في البلد، وإزاء انتهاكات القانون الدولي الإنساني وانتهاكات وتجاوزات حقوق الإنسان، بما في تلك التي تنطوي على عنف جنسي وجنساني،</p>
      </container>
      <container name="وإذ يسلّم كذلك" eId="container_9">
        <p xml:space="preserve">
          <span class="bold italic">	وإذ يسلّم كذلك </span>بدور الموارد الطبيعية المرتبطة بالنزاع، بما في ذلك على سبيل المثال لا الحصر الذهب والقصدير والتنتالوم والتنغستن والنيوبيوم، في تمويل الأنشطة غير المشروعة التي تقوم بها الجماعات المسلحة في جمهورية الكونغو الديمقراطية والمنطقة، وإذ يذكّر باستمرار مجموعة الخبراء في الإبلاغ عن هذه الأنشطة غير المشروعة، <span class="bold italic">وإذ يشدد</span> على أهمية قيام دول المنطقة بتعزيز الشفافية وإمكانية التتبع في مجال صادرات الموارد الطبيعية،</p>
      </container>
      <container name="وإذ يكرر التأكيد" eId="container_10">
        <p xml:space="preserve">
          <span class="bold italic">	وإذ يكرر التأكيد </span>على أن القوات المسلحة وقوات الأمن التابعة لحكومة جمهورية الكونغو الديمقراطية معفاة من الحظر المفروض على توريد المعدات والمساعدة العسكرية على النحو المشار إليه في البيان الصحفي SC/15689 المتفق عليه في 2 أيار/مايو 2024، ومن أي إجراء من إجراءات الإخطار على النحو المبيّن في الفقرتين 1 و 2 أدناه،</p>
      </container>
      <container name="وإذ يقرر" eId="container_11">
        <p xml:space="preserve">	<span class="bold italic">وإذ يقرر </span>أن الحالة في جمهورية الكونغو الديمقراطية ما زالت تشكل تهديدا للسلام والأمن الدوليين في المنطقة،</p>
      </container>
      <container name="وإذ يتصرف" eId="container_12">
        <p xml:space="preserve">	<span class="bold italic">وإذ يتصرف </span>بموجب الفصل السابع من ميثاق الأمم المتحدة،</p>
      </container>
    </preamble>
    <mainBody>
      <paragraph eId="para_13" class="SingleTxt">
        <num>1 -</num>
        <content eId="para_13__content">
          <p xml:space="preserve">	<span class="bold italic">يقرر </span>أن يجدد، حتى 1 تموز/يوليه 2027، التدابير المبينة أو الممددة في الفقرات 1 و 2 و 3 من القرار <a href="https://docs.un.org/ar/S/RES/2783(2025)">2783 (2025)</a>، <span class="bold italic">ويقرر </span>أن يمدد، حتى 1 آب/أغسطس 2027، ولاية فريق الخبراء على النحو المنصوص عليه في الفقرة 6 من القرار <a href="https://docs.un.org/ar/S/RES/2360(2017)">2360 (2017)</a> والفقرة 5 من القرار <a href="https://docs.un.org/ar/S/RES/2783(2025)">2783 (2025)</a>، <span class="bold italic">ويؤكد من جديد </span>الفقرات 4 و 6 (بالصيغة المعدلة بتواريخ الإبلاغ الواردة أدناه) و 7 و 8 من القرار <a href="https://docs.un.org/ar/S/RES/2783(2025)">2783 (2025)</a>، <span class="bold italic">ويقرر كذلك </span>أن يقدم فريق الخبراء إلى المجلس، بعد مناقشة الأمر مع اللجنة، تقريرا لمنتصف المدة في موعد أقصاه 30 كانون الأول/ديسمبر 2026، وتقريرا نهائيا في موعد أقصاه 15 حزيران/يونيه 2027؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_14" class="SingleTxt">
        <num>2 -</num>
        <content eId="para_14__content">
          <p xml:space="preserve">	<span class="bold italic">يؤكد</span> أن الفقرة 1 من هذا القرار تتسق مع الفقرتين 1 و 2 من القرار <a href="https://docs.un.org/ar/S/RES/2667(2022)">2667 (2022)</a> وأن التدابير المنصوص عليها في الفقرة 1 من القرار <a href="https://docs.un.org/ar/S/RES/1807(2008)">1807 (2008)</a> ما زالت سارية على جميع الكيانات غير الحكومية والأفراد العاملين في أراضي جمهورية الكونغو الديمقراطية؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_16" class="SingleTxt">
        <num>3 -</num>
        <content eId="para_16__content">
          <p xml:space="preserve">	<span class="bold italic">يدعو </span>إلى تعزيز التعاون بين الدول كافة، ولا سيما دول المنطقة، وفريق الخبراء، بما في ذلك لغرض ضمان الوصول الآمن ودون عوائق، ولا سيما إلى الأشخاص والوثائق والمواقع الضرورية لتمكين فريق الخبراء من الاضطلاع بولايته، <span class="bold italic">ويعيد تأكيد </span>أهمية ضمان سلامة وأمن أعضاء فريق الخبراء؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_19" class="SingleTxt">
        <num>4 -</num>
        <content eId="para_19__content">
          <p xml:space="preserve">	<span class="bold italic">يقرر </span>أن تسري التدابير المشار إليها في الفقرة 3 من القرار <a href="https://docs.un.org/ar/S/RES/2783(2025)">2783 (2025)</a> على الجماعات المسلّحة (الكيانات والأفراد) التي تعيّنها اللجنة لعرقلتها المتعمّدة والخطيرة لتنفيذ ولاية بعثة منظمة الأمم المتحدة لتحقيق الاستقرار في جمهورية الكونغو الديمقراطية، بما في ذلك من خلال منع الوصول، أو فرض قيود على حرية التنقل، أو التدخل في أنشطة الدوريات والرصد؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_23" class="SingleTxt">
        <num>5 -</num>
        <content eId="para_23__content">
          <p xml:space="preserve">	<span class="bold italic">يشير </span>إلى التزام الأمين العام بأن تبذل الأمم المتحدة كلَّ ما في وسعها لضمان تقديم قتلة عضوي فريق الخبراء والرعايا الكونغوليين الأربعة المرافقين لهما إلى العدالة، ويشدد على أهمية مواصلة تقديم المساعدة، في حدود الموارد المتاحة، إلى جمهورية الكونغو الديمقراطية، في مجال الملاحقات القضائية والتحقيقات الوطنية الجارية، ومواصلة بذل الجهود من أجل تقديم جميع الضالعين في عملية القتل، بما في ذلك عن طريق تخطيطها القتل أو توجيهها أو تمويلها، إلى العدالة؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_28" class="SingleTxt">
        <num>6 -</num>
        <content eId="para_28__content">
          <p xml:space="preserve">	<span class="bold italic">يقرر </span>أن يبقي المسألة قيد نظره.</p>
        </content>
      </paragraph>
    </mainBody>
  </statement>
