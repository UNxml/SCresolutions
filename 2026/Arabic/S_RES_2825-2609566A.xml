      <p xml:space="preserve">
        <docTitle refersTo="#adoption">الذي اتخذه مجلس الأمن في <inline name="adoptionMeeting" title="10188">جلسته 10188</inline>، المعقودة في <docDate date="2026-06-29" refersTo="#adoptionDate">29 حزيران/يونيه 2026</docDate></docTitle>
