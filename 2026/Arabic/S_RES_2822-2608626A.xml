      <p xml:space="preserve">
        <docTitle refersTo="#resolutionNumber">القرار 2822 (2026)</docTitle>
      </p>
      <p xml:space="preserve">
        <docTitle refersTo="#adoption">الذي اتخذه مجلس الأمن في <inline name="adoptionMeeting" title="10171">جلسته 10171</inline>، المعقودة في <docDate date="2026-06-15" refersTo="#adoptionDate">15 حزيران/يونيه 2026</docDate></docTitle>
      </p>
    </coverPage>
    <preamble>
      <formula name="enactingFormula" eId="formula_1">
        <p xml:space="preserve">
          <span class="bold italic">إن مجلس الأمن</span>،</p>
      </formula>
      <container name="إذ يشير" eId="container_2">
        <p xml:space="preserve">	<span class="bold italic">إذ يشير</span> إلى قراراته السابقة بشأن أفغانستان، وإذ يكرر الإعراب عمّا لديه من شواغل خطيرة، كما هو مبيّن في القرار <a href="https://undocs.org/ar/S/RES/2818 (2026)">2818 (2026)</a>، إزاء الحالة في أفغانستان،</p>
      </container>
      <container name="وإذ يؤكد" eId="container_3">
        <p xml:space="preserve">	<span class="bold italic">وإذ يؤكد</span> أهمية الدور الذي ستواصل الأمم المتحدة الاضطلاع به في تعزيز السلام والاستقرار في أفغانستان،</p>
      </container>
      <container name="وإذ يؤكد من جديد" eId="container_4">
        <p xml:space="preserve">	<span class="bold italic">وإذ يؤكد من جديد</span> التزامه القوي بسيادة أفغانستان واستقلالها وسلامتها الإقليمية ووحدتها الوطنية، وكذلك دعمه المستمر لشعب أفغانستان،</p>
      </container>
      <container name="وإذ يشدد" eId="container_5">
        <p xml:space="preserve">	<span class="bold italic">وإذ يشدد </span>على بالغ قلقه من تردّي الأوضاع الاقتصادية والإنسانية في أفغانستان، وإذ يسلّم بضرورة تعزيز المساعدة الإنسانية ودعم توافر احتياجات الإنسان الأساسية والاحتياجات الإنمائية التي تكتسي أهمية حاسمة لتمكين أفغانستان من الاعتماد على الذات في الأجل الطويل، وإذ يكرر تأكيد الأهمية الحيوية لإتاحة وصول المساعدات الإنسانية بشكل كامل وسريع وآمن دون أي عوائق إلى جميع المحتاجين في مختلف أنحاء أفغانستان،</p>
      </container>
      <container name="وإذ يعرب" eId="container_6">
        <p xml:space="preserve">	<span class="bold italic">وإذ يعرب </span>عن بالغ قلقه إزاء التراجع المتزايد والواسع النطاق في احترام حقوق الإنسان والحريات الأساسية، ولا سيما بالنسبة للنساء والفتيات، وإذ يؤكد على أن غياب هذه الحقوق والحريات يجعل السلام والاستقرار والازدهار في البلد أمراً بعيد المنال، وإذ يؤكد من جديد دعوته للتراجع بسرعة عن جميع السياسات والممارسات المتعارضة مع التزامات أفغانستان الدولية فيما يتعلق بحقوق الإنسان، وإذ يحث على إتاحة الإمكانية الكاملة للنساء الأفغانيات العاملات في الأمم المتحدة للوصول إلى منشآت المنظمة في مختلف أنحاء البلد،</p>
      </container>
      <container name="وإذ يعرب" eId="container_7">
        <p xml:space="preserve">	<span class="bold italic">وإذ يعرب </span>عن قلقه الشديد إزاء وجود جماعات إرهابية في أفغانستان لا تزال تشكل تهديدا للسلام والأمن الدوليين، وإذ يؤكد من جديد أهمية مكافحة الإرهاب في أفغانستان، بما يشمل من حدّدته لجنة مجلس الأمن العاملة بموجب القرارات <a href="https://undocs.org/ar/S/RES/1267 (1999)">1267 (1999)</a> و <a href="https://undocs.org/ar/S/RES/1989 (2011)">1989 (2011)</a> و <a href="https://undocs.org/ar/S/RES/2253 (2015)">2253 (2015)</a> من أفراد وجماعات ومؤسسات وكيانات،</p>
      </container>
    </preamble>
    <mainBody>
      <paragraph eId="para_8" class="SingleTxt">
        <num>1 -</num>
        <content eId="para_8__content">
          <p xml:space="preserve">	<span class="bold italic">يقرر</span> تمديد ولاية بعثة الأمم المتحدة لتقديم المساعدة إلى أفغانستان، المبيّنة في الفقرة 2 من هذا القرار، حتى 17 حزيران/يونيه 2027، ويكرر تأكيد دعمه الكامل للعمل الذي تضطلع به البعثة؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_9" class="SingleTxt">
        <num>2 -</num>
        <list eId="para_9_list">
          <intro eId="para_9_list_intro">
            <p xml:space="preserve">	<span class="bold italic">يقرر</span> كذلك أن تقوم البعثة، تحت قيادة الممثلة الخاصة للأمين العام، وبالتشاور الوثيق مع جميع الأطراف الأفغانية المعنية من الجهات الفاعلة السياسية وأصحاب المصلحة، ولا سيما السلطات المعنية، ودعما لشعب أفغانستان بما ينسجم مع ممارسة أفغانستان لسيادتها واضطلاعها بالقيادة وإمساكها بزمام الأمور، بمواصلة الاضطلاع بولايتها المبيّنة أدناه:</p>
          </intro>
          <point eId="para_9_list_point_أ">
            <num>(أ)</num>
            <content eId="para_9_list_point_أ_content">
              <p xml:space="preserve">	تنسيق وتيسير تقديم المساعدات الإنسانية والموارد المالية اللازمة لدعم المساعدة الإنسانية، وفقا للقانون الدولي، بما في ذلك القانون الدولي الإنساني، وبما يتماشى مع مبادئ العمل الإنساني، مع مراعاة أحكام القرار <a href="https://undocs.org/ar/S/RES/2615 (2021)">2615 (2021)</a>، وتعزيز التعاون والاتساق على صعيد أنشطة تأمين احتياجات الإنسان الأساسية والأنشطة الإنسانية في مختلف أنحاء أفغانستان؛ والمساعدة على تحسين فرص وصول جميع المحتاجين، دون تمييز وفي مختلف أنحاء البلد، إلى الأنشطة التي تضطلع بها وكالات العمل الإنساني والإنمائي وموظفوها، بما في ذلك وصول النساء؛ ودعم الجهود الرامية إلى تهيئة الظروف المؤاتية لعودة النازحين داخلياً واللاجئين وإعادة إدماجهم بطريقة طوعية وآمنة وكريمة ومستدامة، والتنسيق مع الكيانات الدولية من جهاتٍ مانحة ومنظمات من أجل تلبية احتياجات الإنسان الأساسية والنهوض بأولويات التنمية الاقتصادية - الاجتماعية التي تساعد على تحقيق الاعتماد على الذات والاستقرار، عبر سبل منها دعم تقديم الخدمات الأساسية، وتيسير النشاطين التجاري والمالي في أفغانستان، ودعم الجهود الرامية إلى تيسير الوصول إلى الأصول المملوكة للمصرف المركزي لأفغانستان لتوظيفها لصالح الشعب الأفغاني؛ ودعم الجهود الرامية إلى زيادة المساءلة والشفافية واستخدام المعونة بفعالية دون تمييز؛</p>
            </content>
          </point>
          <point eId="para_9_list_point_ب">
            <num>(ب)</num>
            <content eId="para_9_list_point_ب_content">
              <p xml:space="preserve">	تقديم خدمات التوعية والمساعي الحميدة، بما في ذلك في إطار المحافل ذات الصلة التي تقودها الأمم المتحدة، بما يشمل فريق المبعوثين الخاصين والممثلين الخاصين للدول الأعضاء المشارِكة فيما يتصل بأفغانستان، لتيسير الحوار بين السلطات المعنية في أفغانستان والجهات المعنية الأخرى صاحبة المصلحة، بما في ذلك دول المنطقة والمجتمع الدولي ككل، وكذلك المجتمع المدني، بهدف تعزيز امتثال أفغانستان لجميع الالتزامات والواجبات الدولية كأساس لإعادة اندماجها في المجتمع الدولي بشكل كامل؛ وتشجيع إقامة حوكمة قائمة على الشمول والتمثيلية والتشارك والاستجابة على الصعيدين الوطني ودون الوطني، دون أي تمييز على أساس نوع الجنس أو الدين أو الأصل العرقي، بمشاركة النساء مشاركة تامة ومتساوية ومجدية وآمنة، وبمشاركة الأقليات والشباب والأشخاص ذوي الإعاقة بشكل مجد؛</p>
            </content>
          </point>
          <point eId="para_9_list_point_ج">
            <num>(ج)</num>
            <content eId="para_9_list_point_ج_content">
              <p xml:space="preserve">	التواصل مع جميع أصحاب المصلحة، بما في ذلك على الصعيدين الوطني ودون الوطني، ومع المجتمع المدني، بما في ذلك المنظمات النسائية الأفغانية، من أجل النهوض بحماية حقوق الإنسان وتعزيزها لجميع الأفغان؛ ودعم وتعزيز تنفيذ أفغانستان لأحكام الصكوك الدولية المتعلقة بحقوق الإنسان والحريات الأساسية التي هي دولة طرف فيها والتي هي ملزمة بها، بما في ذلك اتفاقية القضاء على جميع أشكال التمييز ضد المرأة؛ ودعم تمتّع جميع النساء والفتيات بالمساواة والتمكين وتكافؤ فرص الحصول على التعليم والعمل والرعاية الصحية والعدالة والخدمات الأساسية الأخرى، وضمان حرية تنقلهن ومشاركتهن بصورة تامة ومتساوية ومجدية وآمنة في الحياة العامة وعمليات صنع القرار، تماشيا مع القرار <a href="https://undocs.org/ar/S/RES/1325 (2000)">1325 (2000)</a> والقرارات ذات الصلة؛ وتشجيع منع جميع أشكال العنف ضد الأطفال والقضاء عليها، بما في ذلك العنف الجنسي والجنساني، وحماية حقوق المحتجزين؛ ودعم الجهود الرامية إلى تعزيز حماية الأطفال ومنع انتهاكات حقوق الإنسان والاعتداءات التي تُرتكب ضدهم؛</p>
            </content>
          </point>
          <point eId="para_9_list_point_د">
            <num>(د)</num>
            <content eId="para_9_list_point_د_content">
              <p xml:space="preserve">	إسداء المشورة بشأن تدابير التخفيف من خطر الذخائر المتفجرة وتنسيق تلك التدابير دعما للمبادرات الإنسانية والإنمائية، ودعم تنسيق الأنشطة المضطلع بها في قطاع أعمال إزالة الألغام لأغراض إنسانية؛ ودعم التعاون الإقليمي والدولي بغرض تعزيز السلام والاستقرار والتنمية الاقتصادية والتوصيلية الإقليمية، بما في ذلك الجهود الرامية إلى منع ومكافحة الاتجار غير المشروع بالأسلحة الصغيرة والأسلحة الخفيفة وتكديسها المزعزع للاستقرار وتسرّبها في أفغانستان والمنطقة؛</p>
            </content>
          </point>
          <point eId="para_9_list_point_ه">
            <num>(ه)</num>
            <content eId="para_9_list_point_ه_content">
              <p xml:space="preserve">	تقديم تقارير عن التقدم المحرز في تنفيذ الولاية المنوطة بها على النحو المبين في الفقرات الفرعية (أ) إلى (د) أعلاه، فضلاً عن القيام بأعمال الرصد والتوثيق والإبلاغ وتوفير التحليلات فيما يتصل بالديناميات السياسية والأمنية، والتطورات الاجتماعية والاقتصادية في مختلف أنحاء البلد، وحالة حقوق الإنسان، بما في ذلك حقوق النساء والأطفال، وحالة المدنيين، والتطورات المتعلقة بقطاع العدالة، والحوكمة الشاملة للجميع، والاقتصاد غير المشروع، والآثار الاقتصادية والإنسانية والاجتماعية للكوارث الطبيعية والشحّ المائي والتحديات البيئية في أفغانستان، والمخاطر المرتبطة بالمساعدة التي تنسّقها الأمم المتحدة في أفغانستان، بما في ذلك خطر تحويل مسار المعونة؛</p>
            </content>
          </point>
        </list>
      </paragraph>
      <paragraph eId="para_11" class="SingleTxt">
        <num>3 -</num>
        <content eId="para_11__content">
          <p xml:space="preserve">	<span class="bold italic">يطلب</span> إلى بعثة الأمم المتحدة لتقديم المساعدة إلى أفغانستان أن تقدم المساعدة، ضمن ولايتها وحسب الاقتضاء، إلى فريق الدعم التحليلي ورصد الجزاءات المنشأ بموجب الفقرة 7 من القرار <a href="https://undocs.org/ar/S/RES/1526 (2004)">1526 (2004)</a>؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_14" class="SingleTxt">
        <num>4 -</num>
        <content eId="para_14__content">
          <p xml:space="preserve">	<span class="bold italic">يؤكد</span> الأهمية الحاسمة لاستمرار وجود البعثة وغيرها من وكالات الأمم المتحدة وصناديقها ‏وبرامجها في أنحاء أفغانستان، ويهيب بجميع المعنيين من الأطراف السياسية والجهات صاحبة المصلحة الأفغانية، وبالأخص السلطات المعنية، وكذلك الأطراف الفاعلة الدولية، إلى التنسيق مع البعثة في تنفيذ ولايتها وكفالة سلامة موظفي الأمم المتحدة والأفراد المرتبطين بها وأمنهم وحرية تنقلهم ‏في جميع أرجاء البلد؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_18" class="SingleTxt">
        <num>5 -</num>
        <content eId="para_18__content">
          <p xml:space="preserve">	<span class="bold italic">يطلب</span> إلى الأمين العام أن يقدم إلى المجلس كل ثلاثة أشهر تقريراً عن الحالة في أفغانستان وعن تنفيذ ولاية البعثة، بما في ذلك على الصعيد دون الوطني؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_23" class="SingleTxt">
        <num>6 -</num>
        <content eId="para_23__content">
          <p xml:space="preserve">	<span class="bold italic">يطلب </span>إلى الأمين العام أن يقوم، وفقاً للممارسات الفضلى، بإجراء استعراض استراتيجي لبعثة الأمم المتحدة لتقديم المساعدة إلى أفغانستان وإصدار تقرير خطي بشأن نتائج هذا الاستعراض لتقديمه إلى المجلس بحلول 31 آذار/مارس 2027، بهدف دعم التنفيذ الفعال لولاية البعثة وتحسين التماسك الهيكلي والقضاء على الازدواجية وتعزيز التنسيق بين مختلف أنشطة الأمم المتحدة في أفغانستان، ومعالجة أي تحديات قد تعوق بشكل مباشر قدرة البعثة على الوفاء بعناصر ولايتها؛</p>
        </content>
      </paragraph>
      <paragraph eId="para_29" class="SingleTxt">
        <num>7 -</num>
        <content eId="para_29__content">
          <p xml:space="preserve">	<span class="bold italic">يقرر</span> أن يبقي المسألة قيد نظره الفعلي.</p>
        </content>
      </paragraph>
    </mainBody>
  </statement>
