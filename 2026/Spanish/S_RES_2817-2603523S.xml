      <p xml:space="preserve">
        <docTitle refersTo="#resolutionNumber">		Resolución 2817 (2026)</docTitle>
      </p>
      <p xml:space="preserve">
        <docTitle refersTo="#adoption">Aprobada por el Consejo de Seguridad en su <inline name="adoptionMeeting" title="10119a">10119a sesión</inline>, celebrada el <docDate date="2026-03-11" refersTo="#adoptionDate">11 de marzo de 2026</docDate></docTitle>
      </p>
