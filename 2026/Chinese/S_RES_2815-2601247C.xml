      </p>
      <p xml:space="preserve">
        <docTitle refersTo="#adoption">
          <docDate date="2026-01-30" refersTo="#adoptionDate">2026年1月30日</docDate>安全理事会<inline name="adoptionMeeting" title="10100">10100次会议通过</inline></docTitle>
