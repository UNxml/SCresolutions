      <p xml:space="preserve">
        <docTitle refersTo="#resolutionNumber">第2825(2026)号决议</docTitle>
      </p>
      <p xml:space="preserve">
        <docTitle refersTo="#adoption">
          <docDate date="2026-06-29" refersTo="#adoptionDate">2026年6月29日</docDate>
          <inline name="adoptionMeeting" title="10188">10188次会议通过</inline>
        </docTitle>
