      <p xml:space="preserve">
        <docTitle refersTo="#resolutionNumber">		Résolution 2817 (2026)</docTitle>
      </p>
      <p xml:space="preserve">
        <docTitle refersTo="#adoption">Adoptée par le Conseil de sécurité à sa <inline name="adoptionMeeting" title="10119e">10119e séance</inline>, le <docDate date="2026-03-11" refersTo="#adoptionDate">11 mars 2026</docDate></docTitle>
      </p>
